# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tuncabackend"

# NextAuth
NEXTAUTH_URL="https://tunca-admin.digitalvoyage.agency"
NEXTAUTH_SECRET="your-secret-key-here"

# One-time Vercel admin setup: POST /api/admin/bootstrap with this secret (min 16 chars), then remove or rotate
ADMIN_SETUP_SECRET="generate-a-long-random-string-here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="https://tunca-admin.digitalvoyage.agency"
NEXT_PUBLIC_BASE_URL="https://tunca-admin.digitalvoyage.agency"

# Avukat profil sayfası kökü (duyuru İletişim kutusundaki link). Ana site ayrı domaindeyse tam origin verin.
# Örnek: https://www.ornek.com — link: {origin}/ekip/{slug} olur.
NEXT_PUBLIC_LAWYER_PROFILE_BASE_URL=""
# Profil path öneki (varsayılan /ekip). Örn. /tr/team için "/tr/team" yazın.
NEXT_PUBLIC_LAWYER_PROFILE_PATH="/ekip"

# Multilingual Configuration
NEXT_PUBLIC_DEFAULT_LANGUAGE="TR"
NEXT_PUBLIC_SUPPORTED_LANGUAGES="TR,EN"

# Cloudinary (use either CLOUDINARY_URL or individual variables)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# OR use individual variables:
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Supabase (if using Supabase)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
